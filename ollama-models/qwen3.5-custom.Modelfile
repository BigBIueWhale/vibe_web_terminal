# Based on the Ollama registry model (includes chat template, tool calling,
# vision encoder, and correct GGUF metadata out of the box).
# Requires: ollama pull qwen3.5:27b-q4_K_M
FROM qwen3.5:27b-q4_K_M

PARAMETER num_ctx 131072
PARAMETER num_predict 81920
PARAMETER temperature 1.0
PARAMETER top_k 20
PARAMETER top_p 0.95
PARAMETER repeat_penalty 1.0
PARAMETER presence_penalty 1.5
