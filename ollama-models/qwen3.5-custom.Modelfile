FROM hf.co/unsloth/Qwen3.5-27B-GGUF:Q4_K_M

# Use Ollama's built-in Qwen 3.5 chat template (includes tool calling support).
# Without these, the raw HuggingFace GGUF has no chat template.
TEMPLATE {{ .Prompt }}
RENDERER qwen3.5
PARSER qwen3.5

PARAMETER num_ctx 131072
PARAMETER num_predict 81920
PARAMETER temperature 1.0
PARAMETER top_k 20
PARAMETER top_p 0.95
PARAMETER repeat_penalty 1.0
PARAMETER presence_penalty 1.5
